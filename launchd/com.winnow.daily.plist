<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- テンプレート: __WINNOW_ROOT__ は scripts/install-launchd.sh がインストール時に実パスへ置換する -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.winnow.daily</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__WINNOW_ROOT__/scripts/daily.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>WorkingDirectory</key>
  <string>__WINNOW_ROOT__</string>
  <key>StandardOutPath</key>
  <string>__WINNOW_ROOT__/data/logs/launchd-daily.log</string>
  <key>StandardErrorPath</key>
  <string>__WINNOW_ROOT__/data/logs/launchd-daily.log</string>
</dict>
</plist>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- テンプレート: __WINNOW_ROOT__/__NODE__ は scripts/install-launchd.sh がインストール時に実パスへ置換する -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.winnow.serve</string>
  <key>ProgramArguments</key>
  <array>
    <string>__NODE__</string>
    <string>__WINNOW_ROOT__/scripts/serve.mjs</string>
    <string>--no-timeout</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__WINNOW_ROOT__</string>
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__WINNOW_ROOT__/data/logs/launchd-serve.log</string>
  <key>StandardErrorPath</key>
  <string>__WINNOW_ROOT__/data/logs/launchd-serve.log</string>
</dict>
</plist>
